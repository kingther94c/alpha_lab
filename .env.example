# Copy to `.env` (which is gitignored) and fill in as needed.

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# IBKR (future)
IBKR_USER=
IBKR_PASS=

# Binance — paper/live trading for the P7 book (notebooks/90_crypto_intraday/binance_paper_trade.py)
# Testnet = mock funds: spot https://testnet.binance.vision  ·  USD-M futures https://testnet.binancefuture.com
BINANCE_TESTNET_SPOT_KEY=
BINANCE_TESTNET_SPOT_SECRET=
BINANCE_TESTNET_FUT_KEY=
BINANCE_TESTNET_FUT_SECRET=
# Live (REAL MONEY) — only fill when ready; --mode live ALSO requires CONFIRM_LIVE=YES
BINANCE_SPOT_KEY=
BINANCE_SPOT_SECRET=
BINANCE_FUT_KEY=
BINANCE_FUT_SECRET=
# CONFIRM_LIVE=YES

# Optional override: absolute path to a data dir outside the repo
# ALPHA_LAB_DATA_DIR=
